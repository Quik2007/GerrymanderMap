{
  // Cloudflare Workers config — static-assets-only deploy of the built
  // Vite app. No worker script; CF serves files from `directory` and
  // SPA-routes unknown paths to index.html so client routing works.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mandertracker",
  "compatibility_date": "2026-05-12",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
